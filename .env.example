# Lokale Dev-Variablen — dieses File ist im Repo getrackt, .env (mit echten Werten) NICHT.
# Kopiere nach .env und füll die Werte aus eurem Supabase-Projekt ein.

# Supabase Projekt-Identifier (öffentlich, kein Secret)
VITE_SUPABASE_PROJECT_ID="<your-project-ref>"
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"

# Anon-Key (öffentlich, designed für Client-Side; kein Secret-Risiko, aber gehört nicht in git)
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx_or_eyJ..."

# Optional: Railway/Modal-Backend (leer = direkter Supabase-Call)
VITE_BACKEND_URL=""

# Optional: Public Base URL für QR-Codes
# Leer = window.location.origin. Lovable-Preview ist auf Mobile auth-gated → dort
# absolute URL setzen (z. B. https://fit-your-foot.lovable.app oder eigene Domain).
VITE_PUBLIC_BASE_URL=""
